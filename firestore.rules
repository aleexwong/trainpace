rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User pace plans — only the owning user can read/write
    match /user_pace_plans/{docId} {
      allow read, update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
    }

    // User fuel plans — only the owning user can read/write
    match /user_fuel_plans/{docId} {
      allow read, update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
    }

    // GPX uploads — owner can read/write, soft-delete only
    match /gpx_uploads/{docId} {
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid;
      // No hard delete — use soft delete (deleted: true) via update
    }

    // User bookmarks — only the owning user can read/write
    match /user_bookmarks/{docId} {
      allow read, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
    }

    // Elevation analysis cache — any authenticated user can read/write
    // Cache entries are keyed by routeId, so access is scoped implicitly
    match /elevation_analysis_cache/{docId} {
      allow read, write: if request.auth != null;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
