# Backend API Configuration
# For local development, use localhost; for production, use your deployed API
VITE_GPX_API_URL=http://localhost:3000
# Production: https://gpx-insight-api.vercel.app

# Note: VITE_GEMINI_API_KEY has been moved to backend for security
# No need to configure it here anymore

# Firebase (client SDK config — safe to expose, gated by security rules)
# Local dev: point these at the staging project (trainpace-staging).
# In Vercel these are set per-environment:
#   Production scope  -> trainpace-prod
#   Preview + Dev     -> trainpace-staging
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Mapbox (route visualization)
VITE_MAPBOX_TOKEN=
