# Backend API Configuration
# For local development, use localhost; for production, use your deployed API
VITE_GPX_API_URL=http://localhost:3000
# Production: https://gpx-insight-api.vercel.app

# Note: VITE_GEMINI_API_KEY has been moved to backend for security
# No need to configure it here anymore

# Strava Integration
# Create an app at https://www.strava.com/settings/api
# Client ID is public (safe to prefix with VITE_ and expose to browser)
VITE_STRAVA_CLIENT_ID=

# Client Secret — server-side only, set in Vercel Environment Variables
# Do NOT prefix with VITE_ (must not be exposed to the browser)
# STRAVA_CLIENT_SECRET= (set in Vercel dashboard, not here)
